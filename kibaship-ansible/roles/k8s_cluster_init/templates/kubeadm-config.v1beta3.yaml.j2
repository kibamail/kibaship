---
# kubeadm Configuration v1beta3 for Kubernetes v1.33.x
# Generated by Kibaship k8s_cluster_init role

apiVersion: kubeadm.k8s.io/v1beta3
kind: InitConfiguration
localAPIEndpoint:
  advertiseAddress: {{ hostvars[inventory_hostname]['main_ip'] }}
  bindPort: {{ kube_apiserver_port }}
nodeRegistration:
  criSocket: unix:///run/containerd/containerd.sock
  kubeletExtraArgs:
    node-ip: {{ hostvars[inventory_hostname]['main_ip'] }}
{% if upload_certs %}
certificateKey: {{ kubeadm_certificate_key | default('') }}
{% endif %}

---
apiVersion: kubeadm.k8s.io/v1beta3
kind: ClusterConfiguration
kubernetesVersion: {{ kube_version }}
clusterName: {{ cluster_name }}
{% if groups['kube_control_plane'] | length > 1 %}
controlPlaneEndpoint: {{ kube_control_plane_endpoint }}
{% endif %}
networking:
  serviceSubnet: {{ kube_service_addresses }}
  podSubnet: {{ kube_pods_subnet }}
  dnsDomain: {{ dns_domain }}
apiServer:
  bindPort: {{ kube_apiserver_port }}
  certSANs:
    - localhost
    - 127.0.0.1
    - kubernetes
    - kubernetes.default
    - kubernetes.default.svc
    - kubernetes.default.svc.{{ dns_domain }}
    - {{ hostvars[inventory_hostname]['main_ip'] }}
{% if hostvars[inventory_hostname]['main_access_ip'] is defined %}
    - {{ hostvars[inventory_hostname]['main_access_ip'] }}
{% endif %}
{% for item in groups['kube_control_plane'] %}
    - {{ hostvars[item]['main_ip'] }}
{% if hostvars[item]['main_access_ip'] is defined %}
    - {{ hostvars[item]['main_access_ip'] }}
{% endif %}
    - {{ hostvars[item]['ansible_hostname'] }}
{% endfor %}
{% for item in supplementary_addresses_in_ssl_keys %}
    - {{ item }}
{% endfor %}
  extraArgs:
    anonymous-auth: "false"
    bind-address: {{ kube_apiserver_bind_address }}
    insecure-port: "0"
    profiling: "false"
    audit-log-maxage: "30"
    audit-log-maxbackup: "3"
    audit-log-maxsize: "100"
controllerManager:
  extraArgs:
    bind-address: 0.0.0.0
    profiling: "false"
scheduler:
  extraArgs:
    bind-address: 0.0.0.0
    profiling: "false"
etcd:
  local:
    dataDir: /var/lib/etcd
    serverCertSANs:
      - localhost
      - 127.0.0.1
      - {{ hostvars[inventory_hostname]['main_ip'] }}
{% if hostvars[inventory_hostname]['main_access_ip'] is defined %}
      - {{ hostvars[inventory_hostname]['main_access_ip'] }}
{% endif %}
{% for item in groups['kube_control_plane'] %}
      - {{ hostvars[item]['main_ip'] }}
{% if hostvars[item]['main_access_ip'] is defined %}
      - {{ hostvars[item]['main_access_ip'] }}
{% endif %}
      - {{ hostvars[item]['ansible_hostname'] }}
{% endfor %}
    peerCertSANs:
      - localhost
      - 127.0.0.1
      - {{ hostvars[inventory_hostname]['main_ip'] }}
{% if hostvars[inventory_hostname]['main_access_ip'] is defined %}
      - {{ hostvars[inventory_hostname]['main_access_ip'] }}
{% endif %}
{% for item in groups['kube_control_plane'] %}
      - {{ hostvars[item]['main_ip'] }}
{% if hostvars[item]['main_access_ip'] is defined %}
      - {{ hostvars[item]['main_access_ip'] }}
{% endif %}
      - {{ hostvars[item]['ansible_hostname'] }}
{% endfor %}
dns:
  type: CoreDNS
imageRepository: {{ kube_image_repo }}

---
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
cgroupDriver: systemd
failSwapOn: false
serverTLSBootstrap: true
rotateCertificates: true
maxPods: 110

---
apiVersion: kubeproxy.config.k8s.io/v1alpha1
kind: KubeProxyConfiguration
mode: {{ kube_proxy_mode }}
clusterCIDR: {{ kube_pods_subnet }}