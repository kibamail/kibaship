[kube_control_plane]
@each((node, idx) in control_planes)
kibaship-control-plane-{{ idx + 1 }} ansible_host={{ node.public_ipv4_address }} ip={{ node.private_ipv4_address }} etcd_member_name=etcd{{ idx + 1 }}
@end

[etcd:children]
kube_control_plane

[kube_node]
@each((node, idx) in workers)
kibaship-worker-{{ idx + 1 }} ansible_host={{ node.public_ipv4_address }} ip={{ node.private_ipv4_address }}
@end
