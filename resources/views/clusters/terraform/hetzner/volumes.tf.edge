terraform {
  required_providers {
    hcloud = {
      source  = "hetznercloud/hcloud"
      version = "~> 1.52"
    }
  }

  backend "s3" {
    bucket = "{{ s3_bucket }}"
    key    = "clusters/{{ cluster_id }}/volumes/terraform.tfstate"
    region = "{{ s3_region }}"
    encrypt = true
  }
}

variable "hcloud_token" {
  description = "Hetzner Cloud API Token"
  type        = string
  sensitive   = true
}



variable "cluster_name" {
  description = "Name of the cluster"
  type        = string
}

variable "control_planes_volume_size" {
  description = "Volume size for control plane nodes in GB"
  type        = number
}

variable "workers_volume_size" {
  description = "Volume size for worker nodes in GB"
  type        = number
}

variable "control_plane_server_ids" {
  description = "Map of control plane node IDs to server IDs"
  type        = map(string)
}

variable "worker_server_ids" {
  description = "Map of worker node IDs to server IDs"
  type        = map(string)
}

provider "hcloud" {
  token = var.hcloud_token
}
@each((node, index) in control_planes)
  resource "hcloud_volume" "control_plane_volume_{{ node['slug'] }}" {
  name      = "{{ cluster_name }}-control-{{ node['slug'] }}-volume"
  size      = var.control_planes_volume_size
  server_id = var.control_plane_server_ids["{{ node.id }}"]
  automount = true
  format    = "ext4"

  labels = {
    cluster    = var.cluster_name
    type       = "control-plane-storage"
    node_id    = "{{ node.id }}"
    managed_by = "kibaship"
  }
}

resource "hcloud_volume_attachment" "control_plane_attachment_{{ node['slug'] }}" {
  volume_id = hcloud_volume.control_plane_volume_{{ node['slug'] }}.id
  server_id = var.control_plane_server_ids["{{ node.id }}"]
  automount = true
}
@end

@each((node, index) in workers)
  resource "hcloud_volume" "worker_volume_{{ node['slug'] }}" {
  name      = "{{ cluster_name }}-worker-{{ node['slug'] }}-volume"
  size      = var.workers_volume_size
  server_id = var.worker_server_ids["{{ node.id }}"]
  automount = true
  format    = "ext4"

  labels = {
    cluster    = var.cluster_name
    type       = "worker-storage"
    node_id    = "{{ node.id }}"
    managed_by = "kibaship"
  }
}

resource "hcloud_volume_attachment" "worker_attachment_{{ node['slug'] }}" {
  volume_id = hcloud_volume.worker_volume_{{ node['slug'] }}.id
  server_id = var.worker_server_ids["{{ node.id }}"]
  automount = true
}
@end

# Individual Volume Outputs for Control Planes
@each(node in control_planes)
  output "control_plane_{{ node.slug }}_volume_id" {
  description = "Volume ID for control plane node {{ node.id }}"
  value       = hcloud_volume.control_plane_volume_{{ node['slug'] }}.id
}

output "control_plane_{{ node.slug }}_volume_name" {
  description = "Volume name for control plane node {{ node.id }}"
  value       = hcloud_volume.control_plane_volume_{{ node['slug'] }}.name
}

output "control_plane_{{ node.slug }}_volume_size" {
  description = "Volume size for control plane node {{ node.id }}"
  value       = hcloud_volume.control_plane_volume_{{ node['slug'] }}.size
}

output "control_plane_{{ node.slug }}_attachment_id" {
  description = "Volume attachment ID for control plane node {{ node.id }}"
  value       = hcloud_volume_attachment.control_plane_attachment_{{ node['slug'] }}.id
}
@end

# Individual Volume Outputs for Workers
@each(node in workers)
  output "worker_{{ node.slug }}_volume_id" {
  description = "Volume ID for worker node {{ node.id }}"
  value       = hcloud_volume.worker_volume_{{ node['slug'] }}.id
}

output "worker_{{ node.slug }}_volume_name" {
  description = "Volume name for worker node {{ node.id }}"
  value       = hcloud_volume.worker_volume_{{ node['slug'] }}.name
}

output "worker_{{ node.slug }}_volume_size" {
  description = "Volume size for worker node {{ node.id }}"
  value       = hcloud_volume.worker_volume_{{ node['slug'] }}.size
}

output "worker_{{ node.slug }}_attachment_id" {
  description = "Volume attachment ID for worker node {{ node.id }}"
  value       = hcloud_volume_attachment.worker_attachment_{{ node['slug'] }}.id
}
@end

# Summary Outputs
output "control_plane_volume_ids" {
  description = "Map of control plane node IDs to volume IDs"
  value = {
@each((node, index) in control_planes)
  "{{ node.id }}" = hcloud_volume.control_plane_volume_{{ node['slug'] }}.id{{ index === control_planes.length - 1 ? '' : ',' }}
@end
}
}

output "worker_volume_ids" {
  description = "Map of worker node IDs to volume IDs"
  value = {
@each((node, index) in workers)
  "{{ node.id }}" = hcloud_volume.worker_volume_{{ node['slug'] }}.id{{ index === workers.length - 1 ? '' : ',' }}
@end
}
}
