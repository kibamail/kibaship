# =============================================================================
# KibaCloud Environment Variables
# =============================================================================
# Copy this file to .env and update the values

# Hetzner Cloud API Token
# Get this from: https://console.hetzner.cloud/projects -> API Tokens
HCLOUD_TOKEN=your-hetzner-cloud-api-token-here

# Terraform Backend Configuration (if using remote state)
# TF_VAR_backend_bucket=your-s3-bucket-name
# TF_VAR_backend_key=terraform/staging/terraform.tfstate
# TF_VAR_backend_region=us-east-1
