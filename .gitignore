# =============================================================================
# kibaship .gitignore
# =============================================================================

# Environment variables
.env
.env.local
.env.*.local

# Terraform
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl
terraform.tfplan
terraform.tfplan.*

# SSH Keys
*.pem
*.key
id_rsa*
!*.pub

# Logs
*.log
logs/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
.cache/

# Kubernetes
kubeconfig*
talosconfig*
!kubeconfig.example

# Backup files
*.backup
*.bak
venv/

kubespray/
