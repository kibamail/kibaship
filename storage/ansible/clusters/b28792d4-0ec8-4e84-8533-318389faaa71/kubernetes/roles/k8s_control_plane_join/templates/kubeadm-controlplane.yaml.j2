---
# kubeadm Control Plane Join Configuration {{ kubeadm_config_api_version }}
# Generated by Kibaship k8s_control_plane_join role for: {{ inventory_hostname }}

apiVersion: kubeadm.k8s.io/{{ kubeadm_config_api_version }}
kind: JoinConfiguration
discovery:
  bootstrapToken:
{% if apiserver_loadbalancer_domain_name is defined %}
    apiServerEndpoint: "{{ apiserver_loadbalancer_domain_name }}:{{ loadbalancer_apiserver_port | default(6443) }}"
{% elif kube_control_plane_endpoint is defined %}
    apiServerEndpoint: "{{ kube_control_plane_endpoint }}"
{% else %}
    apiServerEndpoint: "{{ hostvars[groups['kube_control_plane'][0]]['ip'] | default(hostvars[groups['kube_control_plane'][0]]['main_ip']) }}:{{ kube_apiserver_port }}"
{% endif %}
    token: {{ cluster_join_info.token }}
    caCertHashes:
      - sha256:{{ cluster_join_info.discovery_token_ca_cert_hash }}
  tlsBootstrapToken: {{ cluster_join_info.token }}
timeouts:
  discovery: {{ discovery_timeout | default('5m0s') }}
controlPlane:
  localAPIEndpoint:
    advertiseAddress: "{{ hostvars[inventory_hostname]['ip'] | default(hostvars[inventory_hostname]['main_ip']) }}"
    bindPort: {{ kube_apiserver_port }}
{% if fresh_certificate_key is defined %}
  certificateKey: {{ fresh_certificate_key }}
{% elif cluster_join_info.certificate_key is defined %}
  certificateKey: {{ cluster_join_info.certificate_key }}
{% endif %}
nodeRegistration:
  name: {{ kube_override_hostname | default(inventory_hostname) }}
  criSocket: {{ cri_socket }}
  kubeletExtraArgs:
    - name: node-ip
      value: {{ hostvars[inventory_hostname]['ip'] | default(hostvars[inventory_hostname]['main_ip']) }}
{% if 'kube_control_plane' in group_names and 'kube_node' not in group_names %}
  taints:
    - effect: NoSchedule
      key: node-role.kubernetes.io/control-plane
{% else %}
  taints: []
{% endif %}
{% if kubeadm_patches is defined and kubeadm_patches | length > 0 %}
patches:
  directory: {{ kubeadm_patches_dir | default('/etc/kubernetes/patches') }}
{% endif %}